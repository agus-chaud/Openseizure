<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Marca esta app como una Wear OS app — OBLIGATORIO -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Sensores: necesario para acelerómetro -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Para Wear OS 4+: acceso a sensores en background -->
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />

    <!-- Foreground Service: mantiene el monitoreo activo de noche -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <!--
        Android 14 (API 34): un foreground service de tipo "health" exige, ADEMÁS de
        FOREGROUND_SERVICE_HEALTH, AL MENOS UNO de un grupo de permisos de sensores.
        HIGH_SAMPLING_RATE_SENSORS es de tipo "normal" (se otorga al instalar, sin diálogo)
        y satisface ese requisito. Sin esto, startForeground() lanza SecurityException y la app
        crashea al iniciar el monitoreo (validado en hardware, Watch 8 / Wear OS).
    -->
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- WakeLock: evita que el CPU duerma durante el monitoreo -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibración para las alarmas -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        Android 13+ (API 33): mostrar notificaciones requiere este permiso, que el usuario
        debe conceder en runtime. Sin él, el foreground service corre igual pero su
        notificación persistente NO se ve. Lo ideal es que MainActivity lo pida en runtime
        (pendiente); para probar ya, se puede otorgar por adb (ver HARDWARE_RUNBOOK).
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Necesario para comunicación con la Companion App -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!-- Necesario para Wear OS standalone app -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SeizureMonitorService — Fase 1.1
            foregroundServiceType="health" es obligatorio en API 30+ para que el
            OS permita startForeground() desde un Service de monitoreo corporal.
            exported="false": solo esta app puede iniciar el service.
        -->
        <service
            android:name=".service.SeizureMonitorService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!--
            Fase 2.1: Wear Data Layer — recepción de mensajes del teléfono.

            El WearableListenerService es el punto de entrada oficial de Wear OS
            para recibir mensajes Data Layer cuando la app no está en foreground.
            En esta fase, el listener vive dentro de WearDataLayerManager via
            MessageClient.addListener() — funciona mientras el Service está activo.

            Si en el futuro se necesita recibir mensajes con la app en background
            (fuera del ForegroundService), se debe agregar un WearableListenerService
            declarado acá con el intent-filter com.google.android.gms.wearable.BIND_LISTENER.
            Ver TODO en TODOS.md (Fase 4.4: edge case watch fuera de muñeca).
        -->

    </application>

</manifest>
