<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Marca esta app como una Wear OS app — OBLIGATORIO -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Sensores: necesario para acelerómetro -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Para Wear OS 4+: acceso a sensores en background -->
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />

    <!-- Foreground Service: mantiene el monitoreo activo de noche -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />

    <!-- WakeLock: evita que el CPU duerma durante el monitoreo -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibración para las alarmas -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Necesario para comunicación con la Companion App -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!-- Necesario para Wear OS standalone app -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SeizureMonitorService — Fase 1.1
            foregroundServiceType="health" es obligatorio en API 30+ para que el
            OS permita startForeground() desde un Service de monitoreo corporal.
            exported="false": solo esta app puede iniciar el service.
        -->
        <service
            android:name=".service.SeizureMonitorService"
            android:exported="false"
            android:foregroundServiceType="health" />

    </application>

</manifest>
